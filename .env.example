# --- Database (Neon Postgres) ---
# Lấy từ Neon dashboard → Connection string (pooled hoặc direct).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Better Auth ---
# Chuỗi bí mật ký session. Sinh: openssl rand -base64 32
BETTER_AUTH_SECRET="thay-bang-chuoi-ngau-nhien->=16-ky-tu"

# --- Vercel Blob (upload logo shop) ---
# Lấy từ Vercel project → Storage → Blob. Tùy chọn ở local, bắt buộc khi upload.
BLOB_READ_WRITE_TOKEN=""

# --- App ---
# URL gốc dùng cho QR code + link. Local: http://localhost:3000 | Prod: https://ishufa.org
NEXT_PUBLIC_APP_URL="http://localhost:3000"
